{
  "name": "gaslacker",
  "version": "1.1.0",
  "private": true,
  "description": "Slack Web API client library for Google Apps Script.",
  "keywords": [
    "clasp",
    "gas",
    "google-apps-script"
  ],
  "homepage": "https://github.com/yhay81/GASlacker#readme",
  "bugs": {
    "url": "https://github.com/yhay81/GASlacker/issues"
  },
  "license": "MIT",
  "author": "yhay81",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yhay81/GASlacker.git"
  },
  "main": "dist/bundle.js",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:live": "node scripts/verify-live.mjs",
    "build": "pnpm run lint && pnpm run typecheck && pnpm run test && rimraf dist && vite build && cpx appsscript.json dist",
    "deploy": "pnpm run build && clasp push",
    "fmt": "oxfmt --write ."
  },
  "devDependencies": {
    "@google/clasp": "^3.1.3",
    "@types/google-apps-script": "2.0.8",
    "@vitest/coverage-v8": "^4.0.16",
    "braces": ">=3.0.3",
    "cpx": "^1.5.0",
    "gas-entry-generator": "^3.0.0",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.27.0"
}
