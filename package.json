{
  "name": "gaslacker",
  "version": "1.3.0",
  "private": true,
  "description": "Slack Web API client library for Google Apps Script.",
  "keywords": [
    "clasp",
    "gas",
    "google-apps-script"
  ],
  "homepage": "https://github.com/yhay81/GASlacker#readme",
  "bugs": {
    "url": "https://github.com/yhay81/GASlacker/issues"
  },
  "license": "MIT",
  "author": "yhay81",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yhay81/GASlacker.git"
  },
  "main": "dist/bundle.js",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:live": "node scripts/verify-live.mjs",
    "build": "pnpm run lint && pnpm run typecheck && pnpm run test && node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && vite build && tsc -p tsconfig.dts.json && node -e \"fs.copyFileSync('appsscript.json','dist/appsscript.json')\"",
    "deploy": "pnpm run build && clasp push",
    "fmt": "oxfmt --write ."
  },
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "2.0.11",
    "@vitest/coverage-v8": "^4.1.10",
    "gas-entry-generator": "^3.0.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.75.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@11.15.1+sha512.81350b07e53c9538a02f1f2303b4290fa2d7be04e56e2a970c4cc4b417dc761de196edabd49d55c7dc9580db81007c44143e4e3d7e462b3000d23c255122d065"
}
